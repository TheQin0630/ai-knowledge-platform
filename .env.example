NODE_ENV=development
API_PORT=3000

POSTGRES_DB=ai_knowledge
POSTGRES_USER=ai_knowledge
POSTGRES_PASSWORD=replace-with-a-local-database-password
POSTGRES_PORT=5432

REDIS_PASSWORD=replace-with-a-local-redis-password
REDIS_PORT=6379

MINIO_ROOT_USER=replace-with-a-local-minio-user
MINIO_ROOT_PASSWORD=replace-with-a-local-minio-password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_REGION=us-east-1
S3_BUCKET=ai-knowledge-documents

JWT_ACCESS_SECRET=replace-with-at-least-32-random-bytes
JWT_REFRESH_SECRET=replace-with-a-different-32-byte-secret

# Chat provider presets: openai | glm | deepseek | qwen | ollama
CHAT_PROVIDER=glm
CHAT_MODEL=glm-4.5-flash
GLM_API_KEY=replace-with-your-glm-key
CHAT_TIMEOUT_MS=45000

# Keep multiple provider keys locally and switch CHAT_PROVIDER while debugging.
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# DASHSCOPE_API_KEY=

# Generic OpenAI-compatible chat service. Clear CHAT_PROVIDER to use this block.
# CHAT_BASE_URL=https://your-chat-service.example.com/v1
# CHAT_API_KEY=replace-with-your-chat-api-key
# CHAT_MODEL=your-chat-model
# CHAT_TIMEOUT_MS=45000

# Generic OpenAI-compatible embedding service. Without it, retrieval uses keywords only.
# EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
# EMBEDDING_API_KEY=replace-with-your-embedding-api-key
# EMBEDDING_MODEL=your-embedding-model
# EMBEDDING_TIMEOUT_MS=30000
