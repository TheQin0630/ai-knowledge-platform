{
  "name": "ai-knowledge-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise-ready AI knowledge platform with hybrid retrieval, cited RAG, and reproducible evaluation.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm --filter @ai-knowledge/api build && pnpm --filter @ai-knowledge/web build",
    "build:web": "pnpm --filter @ai-knowledge/web build",
    "dev": "pnpm --filter @ai-knowledge/api start:dev",
    "dev:web": "pnpm --filter @ai-knowledge/web dev",
    "lint": "pnpm --filter @ai-knowledge/api lint",
    "lint:web": "pnpm --filter @ai-knowledge/web lint",
    "migration:revert": "pnpm --filter @ai-knowledge/api migration:revert",
    "migration:run": "pnpm --filter @ai-knowledge/api migration:run",
    "migration:show": "pnpm --filter @ai-knowledge/api migration:show",
    "test": "pnpm --filter @ai-knowledge/api test",
    "test:web": "pnpm --filter @ai-knowledge/web test",
    "test:cov": "pnpm --filter @ai-knowledge/api test:cov",
    "test:e2e": "pnpm --filter @ai-knowledge/api test:e2e",
    "test:integration": "pnpm --filter @ai-knowledge/api test:integration",
    "typecheck": "pnpm --filter @ai-knowledge/api typecheck && pnpm --filter @ai-knowledge/web typecheck",
    "typecheck:web": "pnpm --filter @ai-knowledge/web typecheck"
  }
}
